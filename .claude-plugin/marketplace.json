{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "skills-dev",
  "description": "Developer tooling plugins for the Humanists UK monorepo",
  "owner": {
    "name": "Humanists UK"
  },
  "plugins": [
    {
      "name": "php-lsp",
      "description": "PHP language server (Intelephense) with CiviCRM/WordPress stubs and diagnostic tuning",
      "version": "1.0.0",
      "author": {
        "name": "Humanists UK"
      },
      "source": "./plugins/php-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "intelephense": {
          "command": "intelephense",
          "args": ["--stdio"],
          "extensionToLanguage": {
            ".php": "php"
          },
          "settings": {
            "intelephense": {
              "environment": {
                "phpVersion": "8.3.0",
                "includePaths": [
                  "civicrm_custom/extension/phpstan-api4-stubs.php"
                ]
              },
              "stubs": [
                "apache", "bcmath", "Core", "ctype", "curl", "date", "dom",
                "exif", "fileinfo", "filter", "ftp", "gd", "gettext", "gmp",
                "hash", "iconv", "imap", "intl", "json", "ldap", "libxml",
                "mbstring", "meta", "mysqli", "openssl", "pcntl", "pcre",
                "PDO", "pdo_mysql", "Phar", "posix", "random", "readline",
                "Reflection", "regex", "session", "SimpleXML", "soap",
                "sockets", "sodium", "SPL", "standard", "superglobals",
                "tokenizer", "xml", "xmlreader", "xmlwriter", "xsl", "zip",
                "zlib", "wordpress"
              ],
              "diagnostics": {
                "undefinedProperties": false,
                "undefinedMethods": false
              },
              "files": {
                "exclude": [
                  "**/.git/**",
                  "**/node_modules/**",
                  "**/vendor/**/{Tests,tests,test,doc,docs}/**",
                  "wp-admin/**",
                  "wp-includes/**",
                  "wp-content/uploads/**",
                  "wp-content/cache/**",
                  "wp-content/languages/**",
                  "civicrm_custom/extension/cache/**",
                  "civicrm_custom/extension-archive/**"
                ]
              }
            }
          }
        }
      }
    }
  ]
}
